VITE_BACKEND_BASE_URL=http://localhost:3000
VITE_API_BASE_PATH=/api/v1
VITE_HEALTH_PATH=/healthz
VITE_GATE_BASE_PATH=/gate

VITE_SESSION_HOURS=2
VITE_SESSION_REVALIDATE_MARGIN_MIN=5

# Cuando el frontend sirva via Cloudflare Tunnel
# ajusta VITE_BACKEND_BASE_URL al subdominio publico
# y reconstruye la imagen: las VITE_* son build-args del Dockerfile, no runtime.
