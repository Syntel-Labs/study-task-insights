# Base de datos PostgreSQL
DB_HOST=atlas
DB_PORT=5432
DB_NAME=study_task_insights
DB_USER=postgres
DB_PASS=postgres
DB_SCHEMA=sti
DATABASE_URL=postgresql://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=${DB_SCHEMA}

# Puerto expuesto en el host para conectar herramientas externas (MCP, pgAdmin, psql).
# El puerto 5432 suele estar ocupado por otros stacks; usamos 5433 por defecto.
DB_HOST_PORT=5433

# Aplicación (express)
APP_PORT=3000

# Ambiente (development | production)
NODE_ENV=development

# CORS (orígenes permitidos separados por coma).
# Añade aquí los subdominios públicos (p. ej. Cloudflare Tunnel) cuando expongas la API.
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173,http://localhost:8080

# Gate de acceso
ACCESS_ENABLED=false
ACCESS_TOKEN=your-strong-access-token

# Cookie (tiempo en horas)
ACCESS_SESSION_HOURS=2

# Cookie cross-site (true cuando el frontend y el backend viven en dominios distintos,
# p. ej. sti-web.josuesay.com -> sti-api.josuesay.com via Cloudflare Tunnel).
# true => SameSite=None (+ Secure). false => SameSite=Lax (desarrollo local).
COOKIE_CROSS_SITE=false

# LLM / otros
OLLAMA_URL=http://hermes:11434
LLM_MODEL=llama3.1:8b-instruct-q4_K_M
LLM_TIMEOUT_MS=300000
LLM_TEMPERATURE=0.2

# Ollama runtime (aplican igual a los perfiles cpu y gpu)
# -1 => mantener el modelo siempre cargado. '5m' => expulsar tras 5 min idle.
OLLAMA_KEEP_ALIVE=-1
# Requests en paralelo que ollama atiende por modelo cargado.
OLLAMA_NUM_PARALLEL=1

# Demo data: si es true, el seed 03_seed_demo.sql se ejecuta en la primera inicialización.
SEED_DEMO=false
